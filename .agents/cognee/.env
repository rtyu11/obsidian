# cognee 設定ファイル
# GEMINI_API_KEY は環境変数から読み込む（ここには書かない）
# 設定方法: システム環境変数 GEMINI_API_KEY に Google AI Studio のキーを設定

# LLM（スキル分析・改善案生成）
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-3-flash-preview"
LLM_API_KEY="${GEMINI_API_KEY}"

# Embedding（ベクトル検索・スキルマッチング）
EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="text-embedding-004"
EMBEDDING_API_KEY="${GEMINI_API_KEY}"

# 接続テストをバイパス（恒久的なタイムアウト回避設定）
COGNEE_SKIP_CONNECTION_TEST=true

# DB保存先（cogneeのローカルDB）
DB_PATH=".agents/cognee/db"
